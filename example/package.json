{
  "name": "workout-planner-demo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --active-arch-only",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "prepare:core": "npm --prefix ../core run build",
    "start": "npm run prepare:core && concurrently -n SERVER,METRO -c green,blue \"adb reverse tcp:3000 tcp:3000 && npm run start:server\" \"react-native start\"",
    "start:server": "node ./server/index.js",
    "test": "jest"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.85.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "react": "19.2.3",
    "react-native": "0.85.2",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/eslint-config": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
